modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-api"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-health"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-outfit-flow"

[[workflows.workflow]]
name = "typecheck-api"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/api-server && npx tsc --noEmit"

[[workflows.workflow]]
name = "typecheck-mobile"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/mobile && npx tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-health"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "curl -sf 'https://2ffc9079-21c3-4bb9-ac7c-9cfc95cc53e6-00-2m4q5uc8xu18p.expo.picard.replit.dev/api/healthz' | node -e \"const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8')); if(d.status!=='ok') process.exit(1); console.log('Health OK:', JSON.stringify(d))\""

[[workflows.workflow]]
name = "api-outfit-flow"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = """
node -e \"
  const BASE='https://2ffc9079-21c3-4bb9-ac7c-9cfc95cc53e6-00-2m4q5uc8xu18p.expo.picard.replit.dev';
  const https = require('https');
  const http = require('http');
  function req(url, opts={}) {
    return new Promise((resolve,reject)=>{
      const lib = url.startsWith('https') ? https : http;
      const r = lib.request(url, opts, res => {
        let d=''; res.on('data',c=>d+=c); res.on('end',()=>{
          try { resolve({status:res.statusCode,body:JSON.parse(d)}); } catch(e) { resolve({status:res.statusCode,body:d}); }
        });
      });
      r.on('error',reject);
      if(opts.body) r.write(opts.body);
      r.end();
    });
  }
  async function main() {
    // 1. Start job
    const start = await req(BASE+'/api/outfit/start', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt:'casual outfit for college girl in Delhi',portals:['Myntra','Ajio'],budgetMin:500,budgetMax:5000})});
    if(!start.body.jobId) { console.error('FAIL: no jobId', start.body); process.exit(1); }
    const jobId = start.body.jobId;
    console.log('Started job:', jobId);

    // 2. Poll until done (max 30s)
    let attempts=0, data;
    while(attempts<10) {
      await new Promise(r=>setTimeout(r,3000));
      const poll = await req(BASE+'/api/outfit/poll/'+jobId);
      data = poll.body;
      console.log('Poll',++attempts,': status='+data.status+' productsReady='+data.productsReady+' imageReady='+data.imageReady);
      if(data.status==='done' && data.productsReady) break;
      if(data.status==='error') { console.error('FAIL: job error:', data.error); process.exit(1); }
    }
    
    // 3. Validate structure
    if(!data || !data.outfits || data.outfits.length===0) { console.error('FAIL: no outfits'); process.exit(1); }
    const outfit = data.outfits[0];
    if(!outfit.outfitTitle) { console.error('FAIL: no outfitTitle'); process.exit(1); }
    if(!outfit.targetProfile) { console.error('FAIL: no targetProfile'); process.exit(1); }
    if(!outfit.items || outfit.items.length!==3) { console.error('FAIL: expected 3 items, got', outfit.items?.length); process.exit(1); }
    const ids = outfit.items.map(i=>i.id).sort();
    if(JSON.stringify(ids)!==JSON.stringify(['bottom','footwear','top'])) { console.error('FAIL: wrong item ids', ids); process.exit(1); }
    
    // 4. Check products
    for(const item of outfit.items) {
      if(!item.portalProducts || item.portalProducts.length===0) { console.error('FAIL: no products for', item.id); process.exit(1); }
      const p = item.portalProducts[0];
      if(!p.productName || !p.portal || !p.productUrl) { console.error('FAIL: incomplete product', p); process.exit(1); }
    }
    
    // 5. Validate imageReady flag is present (may be true or false)
    if(typeof data.imageReady !== 'boolean') { console.error('FAIL: imageReady not a boolean'); process.exit(1); }
    
    // 6. Validate image endpoint returns 200 or 202
    const imgRes = await req(BASE+'/api/outfit/'+jobId+'/image/0');
    if(imgRes.status!==200 && imgRes.status!==202) { console.error('FAIL: image endpoint returned', imgRes.status); process.exit(1); }
    console.log('Image endpoint:', imgRes.status===200 ? 'READY (cached)' : 'GENERATING (202)');
    
    console.log('ALL CHECKS PASSED');
    console.log('  outfitTitle:', outfit.outfitTitle);
    console.log('  targetProfile:', outfit.targetProfile);
    console.log('  items:', outfit.items.map(i=>i.id+':'+i.portalProducts.length+'products').join(', '));
  }
  main().catch(e=>{ console.error('FAIL: exception', e.message); process.exit(1); });
  \""""

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
